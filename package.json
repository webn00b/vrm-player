{
  "name": "vrm-player",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:circular": "madge --circular --extensions ts src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:regression": "npm run test:circular && vitest run"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@pixiv/three-vrm": "^3.5.0",
    "@pixiv/three-vrm-animation": "^3.5.2",
    "kalidokit": "^1.1.5",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@vitest/coverage-v8": "^4.1.5",
    "madge": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
