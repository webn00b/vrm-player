{
  "name": "vrm-player",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:circular": "madge --circular --extensions ts src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:regression": "npm run test:circular && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@pixiv/three-vrm": "^3.5.0",
    "@pixiv/three-vrm-animation": "^3.5.2",
    "@primevue/themes": "^4.5.4",
    "kalidokit": "^1.1.5",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "three": "^0.170.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "madge": "^8.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  }
}
