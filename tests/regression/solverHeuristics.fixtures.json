    },
    {
      "name": "large lean ramps toward max gain",
      "args": { "baseScale": 0.35, "maxScale": 0.8, "lateralLeanAbs": 0.5 },
      "expected": 0.8,
      "tolerance": 0.000001
    }
  ],
  "armScaleCap": [
    {
      "name": "overscaled arm gets capped by live segment lengths",
      "args": { "rawScale": 1.4, "avatarArmLen": 0.44, "perfSegmentLen": 0.50 },
      "expectedEffectiveScale": 0.924,
      "expectedCap": 0.924,
      "tolerance": 0.000001
    },
    {
      "name": "normal scale stays untouched",
      "args": { "rawScale": 0.92, "avatarArmLen": 0.44, "perfSegmentLen": 0.50 },
      "expectedEffectiveScale": 0.92,
      "expectedCap": null,
      "tolerance": 0.000001
    }
  ],
  "midpointBlend": [
    {
      "name": "crossing centerline forces midpoint anchor",
      "args": { "shoulderCenterOffset": 0.18, "wristCenterOffset": -0.01 },
      "expected": 1,
      "tolerance": 0.000001
    },
    {
      "name": "same-side wrist far from center keeps shoulder anchor",
      "args": { "shoulderCenterOffset": 0.18, "wristCenterOffset": 0.18 },
      "expected": 0,
      "tolerance": 0.000001
    }
  ],
  "handsTogetherBlend": [
    {
      "name": "close wrists on same level trigger folded-hands blend",
      "args": { "shoulderSpan": 0.30, "wristGap": 0.09, "wristLevelDelta": 0.01 },
      "expected": 0.8333333333,
      "tolerance": 0.000001
    },
    {
      "name": "big wrist height difference disables folded-hands branch",
      "args": { "shoulderSpan": 0.30, "wristGap": 0.06, "wristLevelDelta": 0.10 },
      "expected": 0,
      "tolerance": 0.000001
    }
  ],
  "prayerBlend": [
    {
      "name": "prayer needs bent arms and lowered wrists",
      "args": { "handsTogetherBlend": 0.9, "armBendRatio": 0.32, "wristBelowShoulders": 0.8 },
      "expected": 0.72,
      "tolerance": 0.000001
    },
    {
      "name": "straight arms do not activate prayer",
      "args": { "handsTogetherBlend": 1, "armBendRatio": 0.08, "wristBelowShoulders": 1 },
      "expected": 0,
      "tolerance": 0.000001
    }
  ],
  "frontPoseBlendBase": [
    {
      "name": "strong prayer suppresses midpoint/front bias",
      "args": { "midpointBlend": 0.8, "handsTogetherBlend": 0.9, "chestPrayerBlend": 0.95 },
